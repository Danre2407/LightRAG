###############################################################################
### Minimal LightRAG config for a remote Ollama server
###
### Usage:
###   1. Copy this file to `.env`   (cp .env.ollama.example .env)
###   2. Replace 192.168.1.100 below with your Ollama server's IP (both places)
###   3. Make sure the two models are pulled on that server:
###        ollama pull qwen2.5:14b
###        ollama pull bge-m3:latest
###   4. Start the server:  lightrag-server
###
### NOTE: On the Ollama host, Ollama must listen on the network, not just
###       localhost. Set this on the server before starting it:
###        OLLAMA_HOST=0.0.0.0:11434
###############################################################################

### --- Server (where LightRAG itself listens) ---
HOST=0.0.0.0
PORT=9621

###############################################################################
### LLM (chat / extraction model served by Ollama)
###############################################################################
LLM_BINDING=ollama
LLM_BINDING_HOST=http://host.docker.internal:11434
LLM_BINDING_API_KEY=
LLM_MODEL=qwen2.5:14b

### Context window. Must be >= MAX_TOTAL_TOKENS + 2000. Required for Ollama.
OLLAMA_LLM_NUM_CTX=32768

### Seconds. Use a generous value for slow local models — do NOT set 0 here:
### the worker-timeout layer reads it literally (worker timeout = LLM_TIMEOUT*2),
### so LLM_TIMEOUT=0 makes the worker time out instantly ("timeout after 0s").
LLM_TIMEOUT=600

###############################################################################
### Embedding model (also served by Ollama)
### Do NOT change EMBEDDING_MODEL / EMBEDDING_DIM after ingesting documents.
###############################################################################
EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://host.docker.internal:11434
EMBEDDING_BINDING_API_KEY=
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_DIM=768
OLLAMA_EMBEDDING_NUM_CTX=8192

###############################################################################
### Storage (local file-based defaults — no external DB needed)
###############################################################################
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

### No reranker by default
RERANK_BINDING=null
